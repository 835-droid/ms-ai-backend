# =================================================================
# MS-AI Backend .gitignore
# =================================================================

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/
server
main

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.html
coverage.xml

# Go workspace file
go.work

# Dependency directories
vendor/
node_modules/

# Environment files
.env
.env.local
.env.*.local

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/
server.log
access.log
error.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage reports
coverage.txt
coverage.out
*.cover

# Dependency directories
node_modules/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# next.js build output
.next

# nuxt.js build output
.nuxt

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# Temporary folders
tmp/
temp/

# Build artifacts
build/
target/

# Docker
.dockerignore

# Local development
*.sqlite
*.db

# Air live reloading
tmp/

# Test fixtures that might contain sensitive data
test/fixtures/secrets/

# Local development overrides
.env.local
.env.development.local
.env.test.local
.env.production.local

# Backup files
*.bak
*.backup
*.old

# Editor directories and files
!.vscode/extensions.json
.history/*

# macOS
.DS_Store
.AppleDouble
.LSOverride

