# =================================================================
# MS-AI Backend Environment Configuration
# =================================================================
# Copy this file to .env and update values for your environment

# =================================================================
# DATABASE CONFIGURATION
# =================================================================

# MongoDB Connection URI
# Local development: mongodb://localhost:27017
# With authentication: mongodb://username:password@localhost:27017/?authSource=admin
# Production (Atlas): mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017

# Database type (allowed values: mongo, postgres, hybrid)
DB_TYPE=mongo

# Database name
DB_NAME=MSAIDB

# Database timeout (default: 10s)
DB_TIMEOUT=10s

# Database failover enabled (default: false, strict DB_TYPE behavior)
DB_FAILOVER_ENABLED=false

# MongoDB auth override (default: false, prefer URI creds)
DB_MONGO_AUTH_OVERRIDE=false

# MongoDB Authentication (leave empty for local no-auth development)
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin

# Note: Use either MONGO_URI with embedded credentials OR MONGO_USERNAME/MONGO_PASSWORD, not both.
# For local development without auth, leave MONGO_USERNAME and MONGO_PASSWORD empty.

# Connection Pool Settings
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=10

# MongoDB Monitoring
MONGO_ENABLE_MONITORING=true
MONGO_SLOW_QUERY_THRESHOLD=1s

# =================================================================
# SERVER CONFIGURATION
# =================================================================

# Server port
SERVER_PORT=8080

# Environment (development, staging, production)
ENVIRONMENT=development

# =================================================================
# SECURITY CONFIGURATION
# =================================================================

# JWT Secret Key (MUST be at least 32 characters)
# Generate a secure random key: openssl rand -hex 32
JWT_SECRET=your-super-secure-jwt-secret-key-here-minimum-32-characters

# JWT Token Expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# =================================================================
# RATE LIMITING
# =================================================================

# Rate limiting configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# =================================================================
# CORS CONFIGURATION
# =================================================================

# CORS allowed origins (comma-separated)
# Development: http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080
# Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080

# =================================================================
# LOGGING CONFIGURATION
# =================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# =================================================================
# DEVELOPMENT FEATURES
# =================================================================

# Allow WebSocket token in query parameters (legacy support)
WEBSOCKET_ALLOW_QUERY_TOKEN=false

# =================================================================
# PRODUCTION NOTES
# =================================================================
#
# 1. SECURITY:
#    - Use strong, randomly generated JWT_SECRET
#    - Store secrets in environment variables or secret managers
#    - Never commit .env files to version control
#    - Use HTTPS in production
#    - Configure proper CORS origins
#
# 2. DATABASE:
#    - Use connection pooling appropriately for your workload
#    - Monitor slow queries and optimize indexes
#    - Use replica sets for high availability
#    - Enable authentication and TLS
#
# 3. MONITORING:
#    - Set up proper logging aggregation
#    - Configure health checks
#    - Monitor application metrics
#    - Set up alerts for critical issues
#
# 4. PERFORMANCE:
#    - Adjust rate limits based on your needs
#    - Configure appropriate timeouts
#    - Use connection pooling
#    - Optimize database queries

# -------------------------
# WebSocket / Chat Settings
# -------------------------
# WebSocket Configuration
# IMPORTANT: For WebSocket connections, ensure CORS_ORIGINS includes your frontend domain
# Example for development: CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Example for production: CORS_ORIGINS=https://yourdomain.com
# Avoid using CORS_ORIGINS="*" in production.

# Chat Settings (optional tuning)
# Maximum message size accepted by the server (bytes)
# CHAT_MAX_MESSAGE_LENGTH=4096
# Per-client rate limit (messages per minute)
# CHAT_RATE_LIMIT_PER_MINUTE=30

